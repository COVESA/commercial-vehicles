 Vehicle.CurrentLocation - and % accuracy

# want to know a change occurred, CV group don't care what type of change it was
Road.RoadAttribution.ChangeTypeAndConfidence.Type
  description: Type of change type
  datatype: string
  type: sensor
  allowed: [
    'UNKNOWN_TYPE',
    'DETECTED',
    'START',
    'END'
  ]

Road.RoadAttribution.ChangeTypeAndConfidence.Confidence
  datatype: int64
  type: sensor
  description: Confidence as a percentage of change type

